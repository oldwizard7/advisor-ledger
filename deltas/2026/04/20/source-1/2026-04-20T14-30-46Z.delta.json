        },
        {
          "content_hash": "9fbc535bdd32f9e6",
          "style": "NORMAL_TEXT",
          "text": "UCLA Jiaqi Ma"
        },
        {
          "content_hash": "730b68d923a2dd4b",
          "style": "NORMAL_TEXT",
          "text": "名下多篇IEEE顶刊 retraction可查，"
        },
        {
